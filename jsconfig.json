{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./frontend/src/*"]
    },
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "preserve",
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "bundler"
  },
  "include": ["frontend/src/**/*"],
  "exclude": ["node_modules", "frontend/node_modules", "backend"]
}
